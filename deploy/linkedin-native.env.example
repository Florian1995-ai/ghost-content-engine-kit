# LinkedIn Developer app values
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Must match the Authorized redirect URL in LinkedIn Developer Portal
LINKEDIN_REDIRECT_URI=https://linkedin-api.florianrolke.com/linkedin/callback

# Public URL of the native LinkedIn publisher service
LINKEDIN_NATIVE_API_URL=https://linkedin-api.florianrolke.com

# Private bearer token used by local pipelines when they call this service
LINKEDIN_NATIVE_API_KEY=change-me-to-a-long-random-secret

# Persisted OAuth token location inside the Coolify container
LINKEDIN_NATIVE_TOKEN_PATH=/data/linkedin-native-token.json

# LinkedIn API settings
LINKEDIN_API_VERSION=202401
LINKEDIN_SCOPES=openid profile w_member_social
