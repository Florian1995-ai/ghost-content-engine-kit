# Ghost Admin API
GHOST_URL=https://your-ghost-domain.com
GHOST_ADMIN_API_KEY=your_admin_key_id:your_admin_secret

# Site identity used inside generated posts
SITE_NAME="Your Blog Name"
SITE_AUTHOR_NAME="Your Name"

# Apify: used for YouTube transcripts/channel scraping and Reddit FAQ mining
APIFY_API_TOKEN=
APIFY_API_TOKEN_2=
APIFY_API_TOKEN_3=
APIFY_API_TOKEN_4=
APIFY_API_TOKEN_5=

# Optional LLM polish/headline generation via OpenRouter
OPENROUTER_API_KEY=

# Optional Neo4j memory graph for internal FAQ/story enrichment
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Optional additional graphs
NEO4J_CONTENT_URI=
NEO4J_CONTENT_USER=
NEO4J_CONTENT_PASSWORD=
NEO4J_SKOOL_URI=
NEO4J_SKOOL_PASSWORD=

# Optional quote-bank location for community/meeting quote posts
QUOTE_BANK_ROOT=quote-bank/runs

# Optional native LinkedIn publishing
# See linkedin-setup/README.md for full setup.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://linkedin-api.example.com/linkedin/callback
LINKEDIN_NATIVE_API_URL=https://linkedin-api.example.com
LINKEDIN_NATIVE_API_KEY=
LINKEDIN_NATIVE_TOKEN_PATH=.tmp/linkedin-native-token.json
LINKEDIN_API_VERSION=202506
LINKEDIN_SCOPES=openid profile w_member_social
