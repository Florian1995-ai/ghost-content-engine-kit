# LinkedIn Developer app values
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Must exactly match the Authorized redirect URL in LinkedIn Developer Portal
LINKEDIN_REDIRECT_URI=https://linkedin-api.example.com/linkedin/callback

# Public URL of your self-hosted native LinkedIn publisher service
LINKEDIN_NATIVE_API_URL=https://linkedin-api.example.com

# Private bearer token used by local pipelines when they call this service.
# Generate your own long random value. This is not from LinkedIn.
LINKEDIN_NATIVE_API_KEY=replace-with-a-long-random-secret

# Persisted OAuth token location inside the deployed container
LINKEDIN_NATIVE_TOKEN_PATH=/data/linkedin-native-token.json

# LinkedIn REST API settings
LINKEDIN_API_VERSION=202506
LINKEDIN_SCOPES=openid profile w_member_social

